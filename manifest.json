{
  "manifest_version": 3,
  "name": "Dark Mode for Learning Portal",
  "short_name": "Portal Dark Mode",
  "description": "Adds a comfortable dark mode to your learning portal. Easy toggle, remembers your preference.",
  "version": "1.0.0",
  "author": "Your Name",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://learning.ccbp.in/*",
    "https://us.aptabase.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Toggle Dark Mode"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
